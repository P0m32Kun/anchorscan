# AnchorScan 配置模板
# 实际使用时无需手动复制此文件——首次运行任意命令（如 anchorscan web）会
# 自动生成 config/default.yaml，工具路径会从系统 PATH 自动检测。
# 此文件仅作参考；如需自定义，编辑自动生成的 config/default.yaml 即可。

tools:
  rustscan: rustscan       # 留空或填工具名则运行时从 PATH 解析
  nmap: nmap
  httpx: httpx
  nuclei: nuclei

# Go duration（如 30s、5m）；0 表示不限时。档位不会覆盖这些全局设置。
timeouts:
  rustscan: "0"
  nmap: "0"
  httpx: "0"
  nse: "0"
  nuclei: "0"

knowledge_base:
  path: ""

scan:
  ports: top1000           # 可选: top1000、端口范围(100-1000)、或端口 CSV(80,443)；highrisk 仅用于按钮插入
  profile: normal          # 可选: slow, normal, fast

profiles:
  slow:
    host_workers: 1
    rustscan_args: ["--batch-size", "500", "--timeout", "3000", "--tries", "2", "--ulimit", "5000"]
    nmap_args: ["-T2", "--max-retries", "3", "--scan-delay", "100ms"]
    httpx_args: ["-rate-limit", "20", "-threads", "5"]
    nuclei_args: ["-rate-limit", "10", "-c", "5", "-retries", "2"]
  normal:
    host_workers: 3
    rustscan_args: ["--batch-size", "1000", "--tries", "2", "--ulimit", "5000"]
    nmap_args: ["-T3", "--max-retries", "2"]
    httpx_args: ["-rate-limit", "100", "-threads", "20"]
    nuclei_args: ["-rate-limit", "50", "-c", "20"]
  fast:
    host_workers: 8
    rustscan_args: ["--batch-size", "1500", "--tries", "2", "--ulimit", "5000"]
    nmap_args: ["-T4", "--max-retries", "1"]
    httpx_args: ["-rate-limit", "300", "-threads", "50"]
    nuclei_args: ["-rate-limit", "150", "-c", "50"]
